# MCP Server Environment Variables
# 
# Copy this file to .env and fill in values for servers you're using.
# Never commit .env to version control.
# 
# Required for: GitHub MCP Server
# Get token from: https://github.com/settings/tokens
# Scopes needed: repo (read/write access to repositories)
# 
GITHUB_TOKEN=

# Optional: PostgreSQL Database Configuration
# 
# Only needed if postgresql MCP server is enabled.
# Leave empty if using SQLite instead.
# 
# Default: localhost
# Database server hostname or IP
DB_HOST=

# Default: 5432
# PostgreSQL port
DB_PORT=

# Database name
DB_NAME=

# Database user
DB_USER=

# Database password (keep secure!)
DB_PASSWORD=

# Optional: Docker Configuration
# 
# Only needed if docker MCP server is enabled.
# Usually Docker socket is at /var/run/docker.sock
# 
DOCKER_SOCKET=/var/run/docker.sock

# Optional: Playwright Configuration
# 
# Only needed if playwright MCP server is enabled.
# 
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=60000

# Optional: Custom Server Ports
# 
# If running MCP servers on non-standard ports
# 
MCP_FILESYSTEM_PORT=
MCP_GIT_PORT=
MCP_TERMINAL_PORT=

# Optional: Logging Configuration
# 
# Set to 'debug' for verbose logging
# Set to 'info' for normal logging
# Set to 'error' for minimal logging
# 
MCP_LOG_LEVEL=info

# Optional: Development Mode
# 
# Set to 'true' to enable development features
# Disables some security restrictions for testing
# 
MCP_DEV_MODE=false

# Load this file with:
# 
#   export $(cat .env | xargs)
# 
# Or use VS Code extension:
#   https://marketplace.visualstudio.com/items?itemName=mikestead.dotenv
